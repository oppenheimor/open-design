# Open Design — environment variables for Docker / GitHub Actions
# Copy to .env before running docker compose

# ── Image tag (set by GitHub Actions, override locally if needed) ──────────
IMAGE_TAG=latest

# ── GitHub repo (used in GHCR image URL) ───────────────────────────────────
# Replace with your fork, e.g.: myorg/open-design
GITHUB_REPO=nexu-io/open-design